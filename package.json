{
  "name": "ibmi-explorer",
  "version": "1.0.0",
  "description": "IBM i query explorer con visualización de grafos estilo Neo4j",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,yellow \"nodemon server/index.js\" \"vite\"",
    "server": "nodemon server/index.js",
    "client": "vite",
    "build": "vite build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "cytoscape": "^3.29.2",
    "cytoscape-cose-bilkent": "^4.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-jt400": "^5.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4",
    "vite": "^5.4.2"
  }
}
